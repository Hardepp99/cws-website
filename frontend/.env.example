# === Local development (WAMP subdirectory) ===
# Copy to .env.local — change paths if your folder name differs.

# PHP CMS API (server-side; must be reachable from Node)
CMS_API_URL=http://localhost/cws-website/cms/public

# Public site URL — used for canonicals, sitemap, admin SEO preview (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: public CMS URL for next/image (defaults derived from CMS_API_URL at build if unset)
# NEXT_PUBLIC_CMS_PUBLIC_URL=http://localhost/cws-website/cms/public

# WordPress (optional fallback if CMS_API_URL is empty)
WORDPRESS_GRAPHQL_URL=http://localhost/cws-cms/index.php?graphql
NEXT_PUBLIC_WORDPRESS_URL=http://localhost/cws-cms

REVALIDATE_SECRET=change-me-in-production

# Brand defaults (content only — configure outbound mail in Admin → Settings → Email)
CONTACT_EMAIL=info@example.com
SMTP_FROM=noreply@example.com

# Optional: override WhatsApp chat link (digits only, country code included)
# NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# Google Places API — set in cms/config.php or env GOOGLE_PLACES_API_KEY
# GOOGLE_PLACES_API_KEY=
