# Production — copy to .env.local on the server (or set as host environment variables).
# No hardcoded domain in code; set these for YOUR domain.

# Public site URL (canonical, sitemap, JSON-LD) — no trailing slash
NEXT_PUBLIC_SITE_URL=https://www.example.com

# CMS API base — must be reachable from the Node.js process (not the browser)
# Same host as the site, or internal URL if CMS is on another vhost:
CMS_API_URL=https://www.example.com/cms/public

# Optional: public CMS URL if different from CMS_API_URL (for next/image host allowlist)
# Usually same origin as CMS_API_URL:
NEXT_PUBLIC_CMS_PUBLIC_URL=https://www.example.com/cms/public

REVALIDATE_SECRET=generate-a-long-random-secret

# WordPress — leave empty if using PHP CMS only
WORDPRESS_GRAPHQL_URL=
NEXT_PUBLIC_WORDPRESS_URL=
